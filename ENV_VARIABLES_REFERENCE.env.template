# ============================================================
# AC Industries EBITDA Platform — Environment Variables
# Session 11 — Complete Reference
# ============================================================
# NEVER commit actual secrets to git.
# Frontend vars go in Vercel Dashboard → Project → Settings → Environment Variables
# Backend vars go in Railway Dashboard → Service → Variables
# ============================================================


# ============================================================
# FRONTEND (Vercel) — prefix VITE_ so Vite exposes them to the browser
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key only

# Backend URL (your Railway deployment URL)
VITE_BACKEND_URL=https://your-backend.up.railway.app

# Anthropic (Claude AI Insight — useClaudeInsight hook)
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Razorpay public key (safe to expose — this is the key_id, not secret)
VITE_RAZORPAY_KEY_ID=rzp_live_...


# ============================================================
# BACKEND (Railway) — server-side only, never exposed to browser
# ============================================================

# Supabase — service_role key (full DB access, never expose to frontend)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key

# Razorpay — secret credentials
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Python/FastAPI runtime (Railway auto-detects, but set explicitly)
PORT=8000
PYTHON_VERSION=3.11


# ============================================================
# LOCAL DEV (.env.local — git-ignored, frontend only)
# Copy to frontend/.env.local — NEVER commit
# ============================================================

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_BACKEND_URL=http://localhost:8000
VITE_ANTHROPIC_API_KEY=sk-ant-...
VITE_RAZORPAY_KEY_ID=rzp_test_...   # use test key for local dev


# ============================================================
# WHERE TO FIND EACH VALUE
# ============================================================
# Supabase URL + anon key:  Supabase Dashboard → Project → Settings → API
# Supabase service_role:    Supabase Dashboard → Project → Settings → API → service_role (secret)
# Railway URL:              Railway Dashboard → Service → Deployments → public domain
# Vercel URL:               Vercel Dashboard → Project → Domains
# Razorpay key_id/secret:   Razorpay Dashboard → Settings → API Keys
# Razorpay webhook secret:  Razorpay Dashboard → Webhooks → your webhook → secret
# Anthropic API key:        console.anthropic.com → API Keys
